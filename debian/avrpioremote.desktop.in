#!/usr/bin/env xdg-open
[Desktop Entry]
Categories=Utility;Network
Comment=
Exec=/opt/avrpioremote$SUFFIX/avrpioremote$SUFFIX -platform xcb
GenericName=AVRPioRemote
Icon=/opt/avrpioremote$SUFFIX/AVRPioRemote.png
MimeType=
Name=AVRPioRemote
Path=/opt/avrpioremote$SUFFIX
StartupNotify=true
Terminal=false
TerminalOptions=
Type=Application
X-DBUS-ServiceName=
X-DBUS-StartupType=
X-KDE-SubstituteUID=false
X-KDE-Username=
